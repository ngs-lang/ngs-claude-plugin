ns {

	PLUGIN_JSON_PATH = '.claude-plugin/plugin.json'
	MARKETPLACE_JSON_PATH = '.claude-plugin/marketplace.json'

	F versions() {
		{
			'plugin': fetch(PLUGIN_JSON_PATH).version
			'marketplace': fetch(MARKETPLACE_JSON_PATH).plugins.the_one().version
		}
	}

	F release(version:Str) {
		F _version_gt(a:Str, b:Str) {
			F parts(v:Str) v.split('.').map(Int).assert(Transformed(len, 3), "Version must have exactly 3 parts: ${v}")
			a_parts = parts(a)
			b_parts = parts(b)
			for(i;3) {
				a_parts[i] > b_parts[i] returns true
				a_parts[i] < b_parts[i] returns false
			}
			false
		}
		versions().each(F(name, current) {
			_version_gt(version, current).assert("Version ${version} must be higher than ${name} current ${current}")
		})
		section "update version files" {
			plugin = fetch(PLUGIN_JSON_PATH)
			plugin.version = version
			store(PLUGIN_JSON_PATH, plugin, {"pretty": true})
			log("Updated ${PLUGIN_JSON_PATH}")

			marketplace = fetch(MARKETPLACE_JSON_PATH)
			marketplace.plugins.the_one().version = version
			store(MARKETPLACE_JSON_PATH, marketplace, {"pretty": true})
			log("Updated ${MARKETPLACE_JSON_PATH}")
		}
		section "git commit and tag" {
			$(log: git add .claude-plugin/plugin.json .claude-plugin/marketplace.json)
			$(log: git commit -m "Release ${version}")
			$(log: git tag "v${version}")
		}
		section "push" {
			$(log: git push)
			$(log: git push origin "v${version}")
		}
	}
}
